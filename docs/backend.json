
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user, whether they are a maid or an employer.",
      "type": "object",
      "properties": {
        "full_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "user_type": { "type": "string", "enum": ["maid", "employer", "admin"] },
        "avatar_url": { "type": "string" },
        "is_verified": { "type": "boolean" },
        "district": { "type": "string" },
        "bio": { "type": "string" },
        "hourly_rate": { "type": "number" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "languages": { "type": "array", "items": { "type": "string" } },
        "availability": { "type": "string" },
        "rating": { "type": "number" },
        "review_count": { "type": "number" },
        "experience": { "type": "number" }
      },
      "required": ["full_name", "email", "user_type"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Details of a service booking.",
      "type": "object",
      "properties": {
        "employer_id": { "type": "string" },
        "maid_id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "number" },
        "total_price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "services": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["employer_id", "maid_id", "date", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Feedback left by an employer for a maid after a service.",
      "type": "object",
      "properties": {
        "booking_id": { "type": "string" },
        "reviewer_id": { "type": "string" },
        "reviewee_id": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["booking_id", "reviewer_id", "reviewee_id", "rating"]
    },
    "Report": {
      "title": "Report",
      "description": "A moderation report filed by a user.",
      "type": "object",
      "properties": {
        "reporter_id": { "type": "string" },
        "reported_id": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["reporter_id", "reported_id", "reason", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and provider details."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "All service bookings on the platform."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "User reviews and ratings."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Moderation reports."
    }
  }
}
